{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "constr": "Data Source=YOUR_DB_SERVER;Initial Catalog=YOUR_DB_NAME;User ID=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;MultipleActiveResultSets=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Secret": "YOUR_SUPER_SECRET_KEY_MIN_32_CHARACTERS_LONG",
    "Issuer": "http://localhost:5073",
    "Audience": "http://localhost:3000"
  }
}
